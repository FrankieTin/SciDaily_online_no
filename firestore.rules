rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Rules ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming());
      
      function isValidUser(data) {
        return data.keys().hasAll(['displayName']) 
          && (data.get('displayName', '') is string && data.get('displayName', '').size() <= 100)
          && (data.get('theme', 'dustblue') is string)
          && (data.get('visibleTabs', []) is list);
      }

      // --- Subcollections ---
      
      match /papers/{paperId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidPaper(incoming());
        allow update: if isOwner(userId) && isValidPaper(incoming());
        allow delete: if isOwner(userId);

        function isValidPaper(data) {
          return data.id is string && data.title is string && data.title.size() <= 200;
        }
      }

      match /journals/{journalId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidJournal(incoming());
        allow update: if isOwner(userId) && isValidJournal(incoming());
        allow delete: if isOwner(userId);

        function isValidJournal(data) {
          return data.id is string && data.content is string && data.date is string;
        }
      }

      match /sleepRecords/{recordId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSleepRecord(incoming());
        allow update: if isOwner(userId) && isValidSleepRecord(incoming());
        allow delete: if isOwner(userId);

        function isValidSleepRecord(data) {
          return data.id is string && data.date is string;
        }
      }

      match /focusRecords/{recordId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidFocusRecord(incoming());
        allow update: if isOwner(userId) && isValidFocusRecord(incoming());
        allow delete: if isOwner(userId);

        function isValidFocusRecord(data) {
          return data.id is string && data.date is string && data.minutes is number;
        }
      }

      match /studySessions/{sessionId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidStudySession(incoming());
        allow update: if isOwner(userId) && isValidStudySession(incoming());
        allow delete: if isOwner(userId);

        function isValidStudySession(data) {
          return data.id is string && data.date is string && data.startTime is number;
        }
      }

      match /researchPlans/{planId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidResearchPlan(incoming());
        allow update: if isOwner(userId) && isValidResearchPlan(incoming());
        allow delete: if isOwner(userId);

        function isValidResearchPlan(data) {
          return data.id is string && data.title is string && data.title.size() <= 500;
        }
      }

      match /fitnessRecords/{recordId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidFitnessRecord(incoming());
        allow update: if isOwner(userId) && isValidFitnessRecord(incoming());
        allow delete: if isOwner(userId);

        function isValidFitnessRecord(data) {
          return data.id is string && data.loggedDate is string;
        }
      }

      match /achievements/{achievementId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidAchievement(incoming());
        allow update: if isOwner(userId) && isValidAchievement(incoming());
        allow delete: if isOwner(userId);

        function isValidAchievement(data) {
          return data.id is string && data.title is string && data.title.size() <= 200;
        }
      }
    }
  }
}
